    "    - chr2:162142882-162152247\n",
    "    - promoter region: 2:162152247-162154247\n",
    "- CFTR: ENST00000699597.1 \n",
    "    - chr7:117479988-117559913\n",
    "    - promoter region: 7:117477988-117479988\n",
    "- CTRB2: ENST00000303037.13\n",
